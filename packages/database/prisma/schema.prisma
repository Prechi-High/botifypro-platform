generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  fullName     String       @map("full_name")
  role         String       @default("creator")
  plan         String       @default("free")
  createdAt    DateTime     @default(now()) @map("created_at")
  bots         Bot[]
  campaigns    AdCampaign[]
  @@map("users")
}

model Bot {
  id                     String        @id @default(uuid())
  creatorId              String        @map("creator_id")
  creator                User          @relation(fields: [creatorId], references: [id])
  botToken               String        @unique @map("bot_token")
  botUsername            String?       @map("bot_username")
  botName                String?       @map("bot_name")
  webhookSet             Boolean       @default(false) @map("webhook_set")
  isActive               Boolean       @default(true) @map("is_active")
  category               String        @default("general")
  platformAdminConfirmed Boolean       @default(false) @map("platform_admin_confirmed")
  createdAt              DateTime      @default(now()) @map("created_at")
  settings               BotSettings?
  customCommands         BotCommand[]
  botUsers               BotUser[]
  transactions           Transaction[]
  depositTransactions    DepositTransaction[]
  adImpressions          AdImpression[]
  @@map("bots")
}

model BotCommand {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  bot             Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  command         String
  responseText    String   @map("response_text")
  isActive        Boolean  @default(true) @map("is_active")
  commandCategory String   @default("custom") @map("command_category")
  isPrebuilt      Boolean  @default(false) @map("is_prebuilt")
  prebuiltKey     String?  @map("prebuilt_key")
  createdAt       DateTime @default(now()) @map("created_at")
  @@unique([botId, command])
  @@map("bot_commands")
}

model BotSettings {
  id                      String  @id @default(uuid())
  botId                   String  @unique @map("bot_id")
  bot                     Bot     @relation(fields: [botId], references: [id])
  welcomeMessage          String  @default("Welcome! Use the buttons below to get started.") @map("welcome_message")
  currencyName            String  @default("Coins") @map("currency_name")
  currencySymbol          String  @default("🪙") @map("currency_symbol")
  usdToCurrencyRate       Decimal @default(1000) @map("usd_to_currency_rate")
  depositWalletAddress    String? @map("deposit_wallet_address")
  minDepositUsd           Float?  @default(1.0) @map("min_deposit_usd")
  minWithdrawUsd          Decimal @default(0.50) @map("min_withdraw_usd")
  withdrawFeePercent      Decimal @default(0) @map("withdraw_fee_percent")
  oxapayMerchantKey       String? @map("oxapay_merchant_key")
  oxapaySecretKey         String? @map("oxapay_secret_key")
  faucetpayApiKey         String? @map("faucetpay_api_key")
  requireChannelJoin      Boolean @default(false) @map("require_channel_join")
  requiredChannelId       String? @map("required_channel_id")
  requiredChannelUsername String? @map("required_channel_username")
  depositEnabled          Boolean @default(false) @map("deposit_enabled")
  withdrawEnabled         Boolean @default(false) @map("withdraw_enabled")
  balanceEnabled          Boolean @default(false) @map("balance_enabled")
  referralEnabled         Boolean @default(false) @map("referral_enabled")
  @@map("bot_settings")
}

model BotUser {
  id               String        @id @default(uuid())
  botId            String        @map("bot_id")
  bot              Bot           @relation(fields: [botId], references: [id])
  telegramUserId   BigInt        @map("telegram_user_id")
  telegramUsername String?       @map("telegram_username")
  firstName        String        @map("first_name")
  balance          Decimal       @default(0)
  joinedAt         DateTime      @default(now()) @map("joined_at")
  lastActive       DateTime      @default(now()) @map("last_active")
  isBanned         Boolean       @default(false) @map("is_banned")
  channelVerified  Boolean       @default(false) @map("channel_verified")
  adConsent        Boolean?      @default(false) @map("ad_consent")
  transactions     Transaction[]
  depositTransactions DepositTransaction[]
  adImpressions    AdImpression[]
  @@unique([botId, telegramUserId])
  @@map("bot_users")
}

model Transaction {
  id                String   @id @default(uuid())
  botId             String   @map("bot_id")
  bot               Bot      @relation(fields: [botId], references: [id])
  botUserId         String   @map("bot_user_id")
  botUser           BotUser  @relation(fields: [botUserId], references: [id])
  type              String
  amountCurrency    Decimal  @map("amount_currency")
  amountUsd         Decimal  @map("amount_usd")
  status            String   @default("pending")
  gateway           String?
  gatewayTxId       String?  @map("gateway_tx_id")
  depositAddress    String?  @map("deposit_address")
  withdrawAddress   String?  @map("withdraw_address")
  platformFeeAmount Decimal  @default(0) @map("platform_fee_amount")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  @@map("transactions")
}

model DepositTransaction {
  id               String   @id @default(cuid())
  txHash           String   @unique @map("tx_hash")
  botId            String   @map("bot_id")
  botUserId        String   @map("bot_user_id")
  amountUsd        Float    @map("amount_usd")
  amountCrypto     Float    @map("amount_crypto")
  coin             String
  network          String
  recipientAddress String   @map("recipient_address")
  status           String   @default("completed")
  createdAt        DateTime @default(now()) @map("created_at")
  bot              Bot      @relation(fields: [botId], references: [id])
  botUser          BotUser  @relation(fields: [botUserId], references: [id])

  @@map("deposit_transactions")
}

model AdCampaign {
  id                   String         @id @default(uuid())
  advertiserId         String         @map("advertiser_id")
  advertiser           User           @relation(fields: [advertiserId], references: [id])
  title                String
  messageText          String         @map("message_text")
  buttonText           String?        @map("button_text")
  buttonUrl            String?        @map("button_url")
  targetCategory       String         @default("all") @map("target_category")
  budgetUsd            Decimal        @map("budget_usd")
  spentUsd             Decimal        @default(0) @map("spent_usd")
  costPerImpressionUsd Decimal        @default(0.001) @map("cost_per_impression_usd")
  isActive             Boolean        @default(false) @map("is_active")
  isPaid               Boolean        @default(false) @map("is_paid")
  createdAt            DateTime       @default(now()) @map("created_at")
  impressions          AdImpression[]
  @@map("ad_campaigns")
}

model AdImpression {
  id         String     @id @default(uuid())
  campaignId String     @map("campaign_id")
  campaign   AdCampaign @relation(fields: [campaignId], references: [id])
  botId      String     @map("bot_id")
  bot        Bot        @relation(fields: [botId], references: [id])
  botUserId  String     @map("bot_user_id")
  botUser    BotUser    @relation(fields: [botUserId], references: [id])
  shownAt    DateTime   @default(now()) @map("shown_at")
  wasClicked Boolean    @default(false) @map("was_clicked")
  @@map("ad_impressions")
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  data      String?
  service   String   @default("bot-engine")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("logs")
}

