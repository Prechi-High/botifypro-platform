generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                       @id @default(uuid())
  email               String                       @unique
  passwordHash        String                       @map("password_hash")
  fullName            String                       @map("full_name")
  role                String                       @default("creator")
  plan                String                       @default("free")
  createdAt           DateTime                     @default(now()) @map("created_at")
  advertiserBalance   Float                        @default(0) @map("advertiser_balance")
  depositAddress      String?                      @map("deposit_address")
  depositTrackId      String?                      @map("deposit_track_id")
  bots                Bot[]
  adCampaigns         AdCampaign[]
  advertiserDeposits  AdvertiserDepositTransaction[]
  @@map("users")
}

model Bot {
  id                     String        @id @default(uuid())
  creatorId              String        @map("creator_id")
  creator                User          @relation(fields: [creatorId], references: [id])
  botToken               String        @unique @map("bot_token")
  botUsername            String?       @map("bot_username")
  botName                String?       @map("bot_name")
  webhookSet             Boolean       @default(false) @map("webhook_set")
  isActive               Boolean       @default(true) @map("is_active")
  category               String        @default("general")
  platformAdminConfirmed Boolean       @default(false) @map("platform_admin_confirmed")
  createdAt              DateTime      @default(now()) @map("created_at")
  settings               BotSettings?
  customCommands         BotCommand[]
  botUsers               BotUser[]
  transactions           Transaction[]
  depositTransactions    DepositTransaction[]
  referrals              Referral[]
  @@map("bots")
}

model BotCommand {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  bot             Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  command         String
  responseText    String   @map("response_text")
  isActive        Boolean  @default(true) @map("is_active")
  commandCategory String   @default("custom") @map("command_category")
  isPrebuilt      Boolean  @default(false) @map("is_prebuilt")
  prebuiltKey     String?  @map("prebuilt_key")
  createdAt       DateTime @default(now()) @map("created_at")
  @@unique([botId, command])
  @@map("bot_commands")
}

model BotSettings {
  id                      String  @id @default(uuid())
  botId                   String  @unique @map("bot_id")
  bot                     Bot     @relation(fields: [botId], references: [id])
  welcomeMessage          String  @default("Welcome! Use the buttons below to get started.") @map("welcome_message")
  currencyName            String  @default("Coins") @map("currency_name")
  currencySymbol          String  @default("🪙") @map("currency_symbol")
  usdToCurrencyRate       Decimal @default(1000) @map("usd_to_currency_rate")
  depositWalletAddress    String? @map("deposit_wallet_address")
  minDepositUsd           Float?  @default(1.0) @map("min_deposit_usd")
  minWithdrawUsd          Decimal @default(0.50) @map("min_withdraw_usd")
  withdrawFeePercent      Decimal @default(0) @map("withdraw_fee_percent")
  oxapayMerchantKey       String? @map("oxapay_merchant_key")
  oxapaySecretKey         String? @map("oxapay_secret_key")
  faucetpayApiKey         String? @map("faucetpay_api_key")
  requireChannelJoin      Boolean @default(false) @map("require_channel_join")
  requiredChannelId       String? @map("required_channel_id")
  requiredChannelUsername String? @map("required_channel_username")
  depositEnabled          Boolean @default(false) @map("deposit_enabled")
  withdrawEnabled         Boolean @default(false) @map("withdraw_enabled")
  balanceEnabled          Boolean @default(false) @map("balance_enabled")
  referralEnabled         Boolean @default(false) @map("referral_enabled")
  referralRewardAmount    Float?  @default(100) @map("referral_reward_amount")
  welcomeMessageEnabled   Boolean @default(true) @map("welcome_message_enabled")
  manualWithdrawal        Boolean @default(false) @map("manual_withdrawal")
  requiredChannels        Json?   @map("required_channels")
  faucetpayWithdrawalKey  String? @map("faucetpay_withdrawal_key")
  captchaEnabled          Boolean @default(true) @map("captcha_enabled")
  withdrawalPassphrase    String? @map("withdrawal_passphrase")
  bonusEnabled            Boolean @default(true) @map("bonus_enabled")
  bonusAmount             Float?  @map("bonus_amount")
  dailyBonusEnabled       Boolean @default(false) @map("daily_bonus_enabled")
  dailyBonusAmount        Float   @default(10) @map("daily_bonus_amount")
  leaderboardEnabled      Boolean @default(false) @map("leaderboard_enabled")
  leaderboardPeriod       String  @default("7days") @map("leaderboard_period")
  leaderboardBonus1       Float   @default(1000) @map("leaderboard_bonus_1")
  leaderboardBonus2       Float   @default(500) @map("leaderboard_bonus_2")
  leaderboardBonus3       Float   @default(250) @map("leaderboard_bonus_3")
  withdrawProvider        String? @map("withdraw_provider")
  faucetpayConfigured     Boolean @default(false) @map("faucetpay_configured")
  faucetpayApiKeyEncrypted String? @map("faucetpay_api_key_encrypted")
  faucetpayApiKeyLast4    String? @map("faucetpay_api_key_last4")
  faucetpayPayoutCurrency String  @default("USDT") @map("faucetpay_payout_currency")
  oxapayPayoutConfigured  Boolean @default(false) @map("oxapay_payout_configured")
  oxapayPayoutApiKeyEncrypted String? @map("oxapay_payout_api_key_encrypted")
  oxapayPayoutApiKeyLast4 String? @map("oxapay_payout_api_key_last4")

  // ── Pro/VIP Investment Plan ──────────────────────────────────────────────────
  proPlanEnabled          Boolean @default(false) @map("pro_plan_enabled")
  proPlanDepositMin       Float   @default(10) @map("pro_plan_deposit_min")
  proPlanDurationDays     Int     @default(30) @map("pro_plan_duration_days")
  proPlanDailyBonus       Float   @default(50) @map("pro_plan_daily_bonus")
  proPlanReferralReward   Float   @default(200) @map("pro_plan_referral_reward")
  // Multi-tier referral (up to 3 levels)
  proTierReferralEnabled  Boolean @default(false) @map("pro_tier_referral_enabled")
  proTier1Percent         Float   @default(40) @map("pro_tier1_percent")
  proTier2Percent         Float   @default(20) @map("pro_tier2_percent")
  proTier3Percent         Float   @default(5) @map("pro_tier3_percent")
  // OxaPay white-label deposit for pro users
  proOxapayMerchantKey    String? @map("pro_oxapay_merchant_key")
  proOxapaySecretKey      String? @map("pro_oxapay_secret_key")
  proOxapayConfigured     Boolean @default(false) @map("pro_oxapay_configured")

  @@map("bot_settings")
}

model BotUser {
  id               String        @id @default(uuid())
  botId            String        @map("bot_id")
  bot              Bot           @relation(fields: [botId], references: [id])
  telegramUserId   BigInt        @map("telegram_user_id")
  telegramUsername String?       @map("telegram_username")
  firstName        String        @map("first_name")
  balance          Decimal       @default(0)
  joinedAt         DateTime      @default(now()) @map("joined_at")
  lastActive       DateTime      @default(now()) @map("last_active")
  isBanned         Boolean       @default(false) @map("is_banned")
  channelVerified  Boolean       @default(false) @map("channel_verified")
  adConsent        Boolean?      @default(false) @map("ad_consent")
  referredBy       String?       @map("referred_by")
  lastAdReceivedAt DateTime?     @map("last_ad_received_at")
  lastBonusClaimed DateTime?     @map("last_bonus_claimed")
  totalEarned      Decimal       @default(0) @map("total_earned")
  // Pro/VIP plan fields
  isProMember      Boolean       @default(false) @map("is_pro_member")
  proExpiresAt     DateTime?     @map("pro_expires_at")
  proDepositAmount Decimal       @default(0) @map("pro_deposit_amount")
  lastProBonusClaimed DateTime?  @map("last_pro_bonus_claimed")
  transactions     Transaction[]
  depositTransactions DepositTransaction[]
  adImpressions    AdImpression[]
  referralsMade    Referral[]    @relation("ReferrerRelation")
  referralsReceived Referral[]   @relation("ReferredRelation")
  @@unique([botId, telegramUserId])
  @@map("bot_users")
}

model Referral {
  id           String   @id @default(cuid())
  botId        String   @map("bot_id")
  referrerId   String   @map("referrer_id")
  referredId   String   @map("referred_id")
  rewardPaid   Boolean  @default(false) @map("reward_paid")
  rewardAmount Float    @default(0) @map("reward_amount")
  createdAt    DateTime @default(now()) @map("created_at")

  bot          Bot      @relation(fields: [botId], references: [id])
  referrer     BotUser  @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referred     BotUser  @relation("ReferredRelation", fields: [referredId], references: [id])

  @@unique([botId, referredId])
  @@map("referrals")
}

model Transaction {
  id                String   @id @default(uuid())
  botId             String   @map("bot_id")
  bot               Bot      @relation(fields: [botId], references: [id])
  botUserId         String   @map("bot_user_id")
  botUser           BotUser  @relation(fields: [botUserId], references: [id])
  type              String
  amountCurrency    Decimal  @map("amount_currency")
  amountUsd         Decimal  @map("amount_usd")
  status            String   @default("pending")
  gateway           String?
  gatewayTxId       String?  @map("gateway_tx_id")
  depositAddress    String?  @map("deposit_address")
  withdrawAddress   String?  @map("withdraw_address")
  platformFeeAmount Decimal  @default(0) @map("platform_fee_amount")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  @@map("transactions")
}

model DepositTransaction {
  id               String   @id @default(cuid())
  txHash           String   @unique @map("tx_hash")
  botId            String   @map("bot_id")
  botUserId        String   @map("bot_user_id")
  amountUsd        Float    @map("amount_usd")
  amountCrypto     Float    @map("amount_crypto")
  coin             String
  network          String
  recipientAddress String   @map("recipient_address")
  status           String   @default("completed")
  createdAt        DateTime @default(now()) @map("created_at")
  bot              Bot      @relation(fields: [botId], references: [id])
  botUser          BotUser  @relation(fields: [botUserId], references: [id])

  @@map("deposit_transactions")
}

model AdvertiserDepositTransaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  amountUsd   Float    @map("amount_usd")
  status      String   @default("completed")
  gateway     String
  gatewayTxId String   @unique @map("gateway_tx_id")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("advertiser_deposit_transactions")
}

model AdCampaign {
  id                  String    @id @default(uuid())
  advertiserId        String    @map("advertiser_id")
  title               String
  message             String
  imageUrl            String?   @map("image_url")
  buttonText          String?   @map("button_text")
  buttonUrl           String?   @map("button_url")
  budgetUsd           Decimal   @map("budget_usd")
  spentUsd            Decimal   @default(0) @map("spent_usd")
  targetAudienceCount Int       @map("target_audience_count")
  impressionsCount    Int       @default(0) @map("impressions_count")
  activityWindow      String    @map("activity_window")
  status              String    @default("pending_approval")
  approvedAt          DateTime? @map("approved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  advertiser          User      @relation(fields: [advertiserId], references: [id])
  impressions         AdImpression[]
  @@map("ad_campaigns")
}

model AdImpression {
  id          String     @id @default(uuid())
  campaignId  String     @map("campaign_id")
  botUserId   String     @map("bot_user_id")
  botId       String     @map("bot_id")
  servedAt    DateTime   @default(now()) @map("served_at")

  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  botUser     BotUser    @relation(fields: [botUserId], references: [id])

  @@map("ad_impressions")
}

model PlatformSettings {
  id                    String  @id @default(cuid())
  minCampaignBudgetUsd  Float   @default(20) @map("min_campaign_budget_usd")
  adIntervalHours       Int     @default(5) @map("ad_interval_hours")
  cpmStandard           Float   @default(0.6) @map("cpm_standard")
  cpm24hr               Float   @default(1.0) @map("cpm_24hr")
  cpm48hr               Float   @default(1.0) @map("cpm_48hr")
  cpm72hr               Float   @default(0.9) @map("cpm_72hr")
  cpm7day               Float   @default(0.8) @map("cpm_7day")
  updatedAt             DateTime @updatedAt @map("updated_at")
  @@map("platform_settings")
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  data      String?
  service   String   @default("bot-engine")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("logs")
}

model CommandWishlist {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdBy   String   @map("created_by")
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("command_wishlist")
}

